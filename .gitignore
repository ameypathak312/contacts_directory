# ==========================================
# 📂 Root level ignore rules
# ==========================================

# फ्रंटएंड आणि बॅकएंडमधील node_modules ब्लॉक करा
frontend/node_modules/
backend/node_modules/

# ==========================================
# 🔒 Backend Secrets & Environment Variables
# ==========================================
# तुमच्या बॅकएंडमधील सिक्रेट पासवर्ड फाईल GitHub वर जाण्यापासून रोखा
backend/.env

# ==========================================
# 🚀 Production / Build Artifacts
# ==========================================
# फ्रंटएंडचे बिल्ड फोल्डर्स (Angular dist)
frontend/dist/
frontend/.angular/

# ==========================================
# 🪵 Logs and Temporary Files
# ==========================================
# बॅकएंडमध्ये तयार होणाऱ्या लॉग फाईल्स आणि अपलोड केलेले मीडिया
backend/logs/
backend/uploads/

# इतर सिस्टीम फाईल्स
.DS_Store
Thumbs.db